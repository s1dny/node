{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Australia/Sydney",
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "enabledManagers": ["flux", "helm-values", "kubernetes"],
  "flux": {
    "managerFilePatterns": ["/^flux\\/.*\\.ya?ml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/^flux\\/.*\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "matchPaths": ["flux/clusters/**/manifests/apps/immich/**"],
      "groupName": "immich",
      "labels": ["dependencies", "immich"]
    },
    {
      "matchPaths": ["flux/clusters/**/manifests/apps/**"],
      "labels": ["dependencies", "kubernetes"]
    },
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
